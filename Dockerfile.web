# Interview9.ai Web Dockerfile
# Per TGM Unified Architecture Section 12.2

FROM node:20-alpine AS builder
WORKDIR /app
COPY client/package*.json ./
RUN npm ci
COPY client/ ./
ARG VITE_APP_ID=interview9
ARG VITE_API_URL=/api
ENV VITE_APP_ID=$VITE_APP_ID
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

FROM nginx:alpine
RUN addgroup --system --gid 1001 nginx-app && \
    adduser --system --uid 1001 interview9web
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.template.conf /etc/nginx/templates/default.conf.template
ENV API_UPSTREAM=http://api:3001
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:80/health || exit 1
CMD ["nginx", "-g", "daemon off;"]

# Interview9.ai Environment Configuration
# Copy to .env and fill in values

# App Identity
VITE_APP_ID=interview9
APP_DOMAIN=interview9.test.thegreymatter.ai

# API Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Cosmos DB (replace in-memory storage)
COSMOS_CONNECTION_STRING=AccountEndpoint=https://tgm-dev.documents.azure.com:443/;AccountKey=YOUR_KEY_HERE;
COSMOS_DATABASE=interview9

# Anthropic (AI analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Redis (session/cache - optional for dev)
REDIS_URL=redis://localhost:6379

# Auth (Azure AD B2C)
AUTH_ISSUER=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/v2.0/
AUTH_AUDIENCE=your-client-id
JWKS_URI=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/discovery/v2.0/keys
